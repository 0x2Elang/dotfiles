#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '

# Personal shortcuts
alias chezmoi-config='cat ~/.config/chezmoi/chezmoi.toml'

# Make ZED the default editor
export EDITOR=zed
export VISUAL=zed
